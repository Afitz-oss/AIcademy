# AIcademy Environment Variables
#
# HOW TO USE:
# 1. Copy this file and rename the copy to .env (remove the .example)
# 2. Fill in only the keys you need for your current stage (see "Needed at" below)
# 3. Save the file
# 4. Never share your .env file or commit it to GitHub — it's already in .gitignore
#
# You don't need any of these to start. Cursor's built-in AI handles tutoring for
# Stages 0–5. You add keys progressively as you reach the stages that need them.

# ── Cursor SDK ────────────────────────────────────────────────────────────────
# Needed at: Setup (only if you use the CLI onboarding: ./scripts/aicademy.sh)
# Get your key at: https://cursor.com/dashboard/integrations
CURSOR_API_KEY=your-cursor-api-key-here

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Needed at: AI Engineering track — raw API calls, embeddings, RAG, agents
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here

# ── Anthropic (optional) ──────────────────────────────────────────────────────
# Needed at: AI Engineering track — alternative model provider for agents
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-key-here

# ── LangSmith (optional) ──────────────────────────────────────────────────────
# Needed at: AI Engineering track — observability & tracing for LangChain/LangGraph
# Get your key at: https://smith.langchain.com/
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=aicademy

# ── Groq (optional) ───────────────────────────────────────────────────────────
# Needed at: AI Engineering track — fast/cheap inference for agent loops
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-key-here
